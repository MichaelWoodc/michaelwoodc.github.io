// Toggle Accordion UI
jQuery.noConflict();
jQuery(document).ready(function($){
var toggleplus = {
'list-style' : 'none',
'background-image' : 'url(//cdn.georgiasouthern.edu/img/arrow_rightv2.png)',
'background-repeat' : 'no-repeat',
'background-position' : 'left center',
'padding-left' : '23px',
'margin-left': '0px',
'display': 'block'
}
	
var toggleminus = {
'list-style' : 'none',
'background-image' : 'url(//cdn.georgiasouthern.edu/img/arrow_down.png)',
'background-repeat' : 'no-repeat',
'background-position' : 'left center',
'padding-left' : '23px',
'margin-left': '0px'
}

var subtoggleplus = {
'list-style' : 'none',
'background-image' : 'url(//cms.georgiasouthern.edu/~gsu/web_templates/CORE/images/ui/arrow_sub_right.png)',
'background-repeat' : 'no-repeat',
'background-position' : 'left center',
'padding-left' : '23px',
'margin-left': '0px'
}

var subtoggleminus = {
'list-style' : 'none',
'background-image' : 'url(//cms.georgiasouthern.edu/~gsu/web_templates/CORE/images/ui/arrow_sub_down.png)',
'background-repeat' : 'no-repeat',
'background-position' : 'left center',
'padding-left' : '23px',
'margin-left': '0px'
}
jQuery(".btn_toggle").each(function(){
	$(this).attr('tabindex',0);
});	
//New HelpOnClick
clickInterval = window.setInterval(function(){
	jQuery('.helponc-iconpreview').each(function(){
		jQuery(this).attr('tabindex',0);
		jQuery(this).attr('onkeypress','maximizesmallwindow()');
	});

}, 30);
//New Popup HelpOnClick
onClickInterval = window.setInterval(function(){
	jQuery('.textareaDiv').each(function(){
		jQuery(this).attr('onkeypress','handleInvitationClick()()');
	});

}, 30);
interval = window.setInterval(function(){
	jQuery('#__livechat-assist').each(function(){
		var title = jQuery(this).children("img").attr('title');
		jQuery(this).children("img").attr('alt',title);
		clearInterval(interval);
    });
	}, 3000);
		
	jQuery("#__livechat-assist").each(function(){
		jQuery(this).attr('tabindex',0);
	});	
	function genUrlVars(url){
		var vars = [], hash;
		var hashes = url.slice(url.indexOf('?') +1).split('&');
		for (var i = 0; i<hashes.length; i++){
			hash = hashes[i].split(";");
			vars.push(hash[0]);
			vars[hash[0]] = hash[1];
		}
		return vars;
	}
	jQuery("#__livechat-assist").keypress(function(){	
		var url = jQuery("#__livechat-assist").next("script").html().substring("po.src=");
		var temp = genUrlVars(url)+"";
		var newurl = "https://web.archive.org/web/20220413174658/https://app.helponclick.com/help?"+temp.replace("'","");
		console.log(newurl);
		window.open(newurl,'winname','menubar=no,toolbar=no,location=no,directories=no,status=no,scrollbars=no,resizable=no,dependent,width=800,height=620,left=0,top=0');
	});
jQuery("img").each(function(){
	 if (!jQuery(this).attr('alt')) // check if current image tag has alt attribute
		jQuery(this).attr('alt','');
});
jQuery(".horizontal .menu-item a").each(function(){
	$(this).addClass( "button-slanted");
});
jQuery(".horizontal .menu-item a").each(function(){
	$(this).wrapInner( "<span class='button-slanted-content'>");
});	
jQuery('.bann-home').each(function(){
		jQuery(this).attr('role','banner');
});
jQuery(".btn_toggle").css(toggleplus);	
jQuery(".btn_toggle").toggle(function () { jQuery(this).css(toggleminus); }, function () { jQuery(this).css(toggleplus);});
jQuery(".btn_toggle").click(function(){jQuery(".slide_toggle.subtoggle div.btn_dropmenu").hide(); 
jQuery(".slide_toggle.subtoggle div.dropmenu").hide();}); 
jQuery(".slide_toggle.subtoggle .btn_toggle").css(subtoggleplus);
jQuery(".slide_toggle.subtoggle .btn_toggle").toggle(
	function(){jQuery(this).css(subtoggleminus);},
    function(){jQuery(this).css(subtoggleplus);}
  );
jQuery('.btn_dropmenu').append('<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/images/ui/dropmenu_arrow_down.png" class="btn_dropmenu_arrow" />');
     jQuery('.btn_dropmenu').toggle(
     function(){jQuery('.btn_dropmenu_arrow').attr('src', '//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/images/ui/dropmenu_arrow_up.png');},
     function(){jQuery('.btn_dropmenu_arrow').attr('src', '//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/images/ui/dropmenu_arrow_down.png');}     
     );
}); 

// CHHS Scripts for Undergrad Majors, Minors, and Advisement Pages
jQuery.noConflict();
jQuery(document).ready(function($){
jQuery('.btn_programinfo').append('Quick Facts<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/css/images/ui/icon_programinfo2.png" alt="Program Info">');
jQuery('.btn_gotosite').append('Go To Website<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/css/images/ui/icon_goto2.png" alt="Visit Website">');
jQuery('.fl_info').hide();
jQuery(".btn_programinfo, .fl_trigger").click(function(){ 
	jQuery(this).parent().find('.fl_info').stop().slideToggle(200, 'swing'); 
	jQuery(this).parent().toggleClass('fl_style1'); 
	jQuery(this).parent().siblings().removeClass('fl_style1'); 
	jQuery(this).parent().siblings().find('.fl_info').hide();
	jQuery(this).parent().find('h6.fl_trigger').wrapInner('<span/>').toggleClass('ribbon');
	jQuery(this).parent().siblings().find('h6.fl_trigger').removeClass('ribbon');
	jQuery(this).parent().siblings().find('h6.fl_trigger span').contents().unwrap();
	});
jQuery('.icon_careers').prepend('<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/css/images/ui/icon_careers.png" alt="Related Info">');
