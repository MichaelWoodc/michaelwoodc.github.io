jQuery('.icon_contact').prepend('<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/css/images/ui/icon_contact.png" alt="Related Info">');
jQuery('.icon_test').prepend('<img src="//web.archive.org/web/20220413174658/https://cms.georgiasouthern.edu/~gsu/web_templates/CORE/css/images/ui/icon_test.png" alt="Related Info">');
